# OptiFerre SaaS — Configuración
# ================================

# --- Aplicación ---
APP_NAME=OptiFerre SaaS
APP_ENV=development
APP_SECRET_KEY=cambia-esta-clave-super-secreta-en-produccion
APP_BASE_URL=http://localhost:8501

# --- Base de datos (SQLAlchemy) ---
# SQLite por defecto. Para producción usa PostgreSQL:
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/optiferre
DATABASE_URL=sqlite:///optiferre.db

# --- Stripe ---
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_STARTER=price_xxx_starter_mensual
STRIPE_PRICE_PRO=price_xxx_pro_mensual
STRIPE_PRICE_ENTERPRISE=price_xxx_enterprise_mensual

# --- Servicio de integración (cotización separada) ---
SALES_CONTACT_EMAIL=ventas@optiferre.com
SALES_CONTACT_PHONE=+57 300 000 0000
